{
    "name": "updive-nsm/updive-nsm",
    "type": "project",
    "description": "Updive NSM - A fully featured network monitoring system.",
    "keywords": [
        "network",
        "monitoring",
        "discovery",
        "alerting",
        "billing",
        "snmp",
        "distributed"
    ],
    "homepage": "https://updive.uz/",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": "^8.2",
        "ext-curl": "*",
        "ext-gd": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-pcre": "*",
        "ext-pdo": "*",
        "ext-session": "*",
        "ext-simplexml": "*",
        "ext-sockets": "*",
        "ext-xml": "*",
        "ext-zlib": "*",
        "amenadiel/jpgraph": "^4",
        "clue/socket-raw": "^1.4",
        "dapphp/radius": "^3.0",
        "easybook/geshi": "^1.0.8",
        "enshrined/svg-sanitize": "^0.22.0",
        "fico7489/laravel-pivot": "^3.0",
        "influxdata/influxdb-client-php": "^3.8",
        "influxdb/influxdb-php": "^1.15",
        "jalle19/certificate-parser": "^4.0",
        "justinrainbow/json-schema": "^6.4",
        "laravel-notification-channels/webpush": "^10.0",
        "laravel/framework": "^12.10",
        "laravel/tinker": "^3.0",
        "laravel/ui": "^4.6",
        "librenms/laravel-vue-i18n-generator": "dev-master",
        "mews/purifier": "^3.4",
        "nesbot/carbon": "^3.8",
        "nunomaduro/laravel-console-summary": "^1.13",
        "pear/console_color2": "^0.1",
        "mikepultz/netdns2": "^1.5",
        "php-amqplib/php-amqplib": "^3.1",
        "phpmailer/phpmailer": "^7.0",
        "predis/predis": "^3.0",
        "socialiteproviders/manager": "^4.8",
        "spatie/laravel-ignition": "^2.9",
        "spatie/laravel-permission": "^6.16",
        "symfony/yaml": "^7.2",
        "tightenco/ziggy": "^2.0"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.5",
        "coding-socks/lost-in-translation": "^0.3.5",
        "composer/composer": "^2.8",
        "fakerphp/faker": "^1.23",
        "friendsofphp/php-cs-fixer": "^3.66",
        "fruitcake/laravel-debugbar": "^4.1",
        "larastan/larastan": "^3.1",
        "laravel/boost": "^2.0",
        "laravel/dusk": "^8.2.2",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "php-parallel-lint/php-parallel-lint": "^1.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-mockery": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^11.5.33 || ^12.3.7",
        "rector/rector": "^2.1"
    },
    "suggest": {
        "ext-gmp": "Used for browser push notifications",
        "ext-ldap": "*",
        "ext-memcached": "Required if you utilize wrapper based distributed polling",
        "ext-mysqlnd": "*",
        "ext-posix": "Allows for additional validation tests"
    },
    "config": {
        "discard-changes": true,
        "optimize-autoloader": true,
        "platform-check": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": false
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "nunomaduro/laravel-console-summary",
                "facade/ignition",
                "socialiteproviders/manager"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app",
            "UpdiveNSM\\": "UpdiveNSM",
            "UpdiveNSM\\Plugins\\": "html/plugins",
            "UpdiveNSM\\Interfaces\\Plugins\\": "UpdiveNSM/Interfaces/Plugins/",
            "UpdiveNSM\\Tests\\": "tests",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "classmap": [
            "vendor/dapphp/radius"
        ],
        "files": [
            "includes/helpers.php"
        ],
        "exclude-from-classmap": [
            "/vendor/laravel/laravel/database/",
            "/vendor/laravel/laravel/app/",
            "/html/plugins",
            "/vendor/marc-mabe/php-enum/stubs/Stringable.php"
        ]
    },
    "scripts": {
        "pre-install-cmd": "UpdiveNSM\\ComposerHelper::preInstall",
        "post-install-cmd": [
            "UpdiveNSM\\ComposerHelper::postInstall",
            "Illuminate\\Foundation\\ComposerScripts::postInstall",
            "@php artisan vue-i18n:generate --multi-locales --format=umd",
            "@php artisan view:cache",
            "@php artisan optimize",
            "@php artisan config:clear"
        ],
        "pre-update-cmd": "UpdiveNSM\\ComposerHelper::preUpdate",
        "post-update-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postUpdate"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": "UpdiveNSM\\ComposerHelper::postRootPackageInstall",
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "support": {
        "issues": "https://github.com/UpdiveNSM/UpdiveNSM/issues/",
        "forum": "https://community.UpdiveNSM.org/",
        "chat": "https://discord.gg/UpdiveNSM",
        "source": "https://github.com/UpdiveNSM/UpdiveNSM/",
        "docs": "https://docs.UpdiveNSM.org/"
    },
    "funding": [
        {
            "type": "opencollective",
            "url": "https://opencollective.com/UpdiveNSM"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true
}
